# MongoDB connection string
MONGO_URI=mongodb://127.0.0.1:27017/ai-crypto-advisor

# JWT signing secret (required)
JWT_SECRET=your-secret-here

# Frontend origin for CORS (production / deployed client)
CLIENT_URL=http://localhost:5173

# Server port
PORT=5000

# Optional: OpenRouter API key for live AI insights
# OPENROUTER_API_KEY=

# Optional: preferred OpenRouter model
# OPENROUTER_MODEL=
