# MongoDB connection string
MONGO_URI=mongodb://127.0.0.1:27017/ai-crypto-advisor

# JWT signing secret (required)
JWT_SECRET=your-secret-here

# Frontend origin(s) for CORS — required in production on Render
# Single URL:  CLIENT_URL=https://your-app.vercel.app
# Multiple:    CLIENT_URL=https://your-app.vercel.app,https://your-app-git-main.vercel.app
CLIENT_URL=http://localhost:5173

# Optional: allow any https://*.vercel.app preview deployment (useful for PR previews)
# ALLOW_VERCEL_PREVIEWS=true

# Server port
PORT=5000

# Optional: OpenRouter API key for live AI insights
# OPENROUTER_API_KEY=

# Optional: preferred OpenRouter model
# OPENROUTER_MODEL=
